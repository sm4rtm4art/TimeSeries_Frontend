# Environment (local, development, test, production)
ENVIRONMENT=development

# Public API base URL used by the frontend (set this in Vercel too)
NEXT_PUBLIC_API_BASE_URL=https://dev-api.example.com

# Debug mode (true/false)
DEBUG=false

# Use mock data for development (true/false)
MOCK_DATA=false

# Maximum data points to load
MAX_DATA_POINTS=5000
